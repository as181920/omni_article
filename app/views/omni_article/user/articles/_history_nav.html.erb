<style>
  .omni-article-history-nav {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 9999;
    height: 56px;
    display: flex;
    background: #fff;
    border-top: 1px solid #e9e9e9;
    box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.06);
  }

  .omni-article-history-nav-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #333;
    line-height: 1.2;
  }

  .omni-article-history-nav-icon {
    font-size: 18px;
    margin-bottom: 2px;
  }

  .omni-article-history-nav-text {
    font-size: 12px;
  }

  .omni-article-history-nav-placeholder {
    height: 64px;
  }
</style>

<div class="omni-article-history-nav">
  <a href="javascript:history.back();" class="omni-article-history-nav-item">
    <span class="omni-article-history-nav-icon">←</span>
    <span class="omni-article-history-nav-text"><%= t("omni_article.history_back") %></span>
  </a>

  <a href="javascript:history.forward();" class="omni-article-history-nav-item">
    <span class="omni-article-history-nav-icon">→</span>
    <span class="omni-article-history-nav-text"><%= t("omni_article.history_forward") %></span>
  </a>
</div>

<div class="omni-article-history-nav-placeholder"></div>
